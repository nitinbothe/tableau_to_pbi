  "calculations": [
    {
      "tableau_calculation": "COUNT([session_id])",
      "pbi_table": "sessions",
      "pbi_object": "Total Sessions",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "COUNTD([user_id])",
      "pbi_table": "sessions",
      "pbi_object": "Unique Visitors",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "SUM(IF [converted] THEN 1 ELSE 0 END) / COUNT([session_id])",
      "pbi_table": "sessions",
      "pbi_object": "Conversion Rate",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "AVG([session_duration])",
      "pbi_table": "sessions",
      "pbi_object": "Avg Session Duration",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "SUM([revenue])",
      "pbi_table": "sessions",
      "pbi_object": "Total Revenue",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "SUM([revenue]) / COUNT([session_id])",
      "pbi_table": "sessions",
      "pbi_object": "Revenue per Session",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "{FIXED [channel] : SUM([revenue])}",
