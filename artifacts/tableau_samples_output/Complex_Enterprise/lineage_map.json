  "calculations": [
    {
      "tableau_calculation": "SUM([quantity] * [unit_price])",
      "pbi_table": "fact_sales",
      "pbi_object": "Gross Revenue",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "SUM(IF [order_status] != \"Cancelled\" AND [is_returned] = FALSE THEN [quantity] * [unit_price] * (1 - [discount_pct]) ELSE 0 END)",
      "pbi_table": "fact_sales",
      "pbi_object": "Net Revenue",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "SUM([quantity] * [unit_cost])",
      "pbi_table": "fact_sales",
      "pbi_object": "COGS",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "[C_NetRev] - [C_COGS] - SUM([shipping_cost])",
      "pbi_table": "fact_sales",
      "pbi_object": "Gross Profit",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "ZN([C_GrossProfit] / [C_NetRev])",
      "pbi_table": "fact_sales",
      "pbi_object": "Gross Margin %",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "SUM([quantity] * [unit_price] * (1 - [discount_pct]) * [tax_rate])",
      "pbi_table": "fact_sales",
      "pbi_object": "Tax Amount",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "[C_NetRev] + [C_TaxAmt]",
      "pbi_table": "fact_sales",
      "pbi_object": "Total Revenue incl Tax",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "SUM(IF [is_returned] = TRUE THEN 1 ELSE 0 END) / COUNT([sale_id])",
      "pbi_table": "fact_sales",
      "pbi_object": "Return Rate",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "{FIXED [customer_id] : SUM([quantity] * [unit_price])}",
      "pbi_table": "fact_sales",
      "pbi_object": "Revenue per Customer",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "{FIXED [product_id] : SUM([quantity] * [unit_price])}",
      "pbi_table": "fact_sales",
      "pbi_object": "Revenue per Product",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "{FIXED [region], [channel] : SUM([quantity] * [unit_price])}",
      "pbi_table": "fact_sales",
      "pbi_object": "Revenue by Region-Channel",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "{EXCLUDE [territory] : SUM([quantity] * [unit_price])}",
      "pbi_table": "fact_sales",
      "pbi_object": "Revenue excl Territory",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "{INCLUDE [subcategory] : SUM([quantity] * [unit_price])}",
      "pbi_table": "fact_sales",
      "pbi_object": "Revenue incl Subcategory",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "RUNNING_SUM(SUM([quantity] * [unit_price]))",
      "pbi_table": "fact_sales",
      "pbi_object": "Running Total Revenue",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "RUNNING_AVG(SUM([quantity] * [unit_price]))",
      "pbi_table": "fact_sales",
      "pbi_object": "Running Avg Revenue",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "RUNNING_COUNT(SUM([quantity]))",
      "pbi_table": "fact_sales",
      "pbi_object": "Running Count",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "RANK(SUM([quantity] * [unit_price]))",
      "pbi_table": "fact_sales",
      "pbi_object": "Revenue Rank",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "RANK_DENSE(SUM([quantity] * [unit_price]))",
      "pbi_table": "fact_sales",
      "pbi_object": "Revenue Rank Dense",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "WINDOW_AVG(SUM([quantity] * [unit_price]), -2, 0)",
      "pbi_table": "fact_sales",
      "pbi_object": "Moving Avg 3-Period",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "WINDOW_MAX(SUM([quantity] * [unit_price]))",
      "pbi_table": "fact_sales",
      "pbi_object": "Window Max Revenue",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "STDEV(SUM([quantity] * [unit_price]))",
      "pbi_table": "fact_sales",
      "pbi_object": "Revenue StdDev",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "COUNTD([sale_id])",
      "pbi_table": "fact_sales",
      "pbi_object": "Order Count",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "COUNTD([customer_id])",
      "pbi_table": "fact_sales",
      "pbi_object": "Unique Customers",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "COUNTD([product_id])",
      "pbi_table": "fact_sales",
      "pbi_object": "Unique Products Sold",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "IF [C_RevPerCust] > 100000 THEN \"Enterprise\" ELSEIF [C_RevPerCust] > 50000 THEN \"Mid-Market\" ELSEIF [C_RevPerCust] > 10000 THEN \"SMB\" ELSE \"Startup\" END",
      "pbi_table": "fact_sales",
      "pbi_object": "Customer Tier",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "{FIXED : SUM(IF [year] = YEAR(TODAY()) AND [is_returned] = FALSE THEN [quantity] * [unit_price] ELSE 0 END)}",
      "pbi_table": "fact_sales",
      "pbi_object": "YTD Revenue",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "[email] = USERNAME()",
      "pbi_table": "fact_sales",
      "pbi_object": "Is My Account",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "ISMEMBEROF(\"Regional Managers\")",
