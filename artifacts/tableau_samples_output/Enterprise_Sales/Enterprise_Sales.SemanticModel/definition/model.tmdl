		returnErrorValuesAsNull

annotation PBI_QueryOrder = ["Orders","Customers","Calendar","Target Margin","Top N"]

ref table Orders
ref table Customers
ref table Calendar
ref table 'Target Margin'
ref table 'Top N'

ref relationship 728b0f65-26ce-4de8-8ec3-9d0efca614cc
ref relationship 23a64dc4-5a1d-451c-9498-b078980c4630
ref relationship 41dbb261-36e3-43e5-a9e1-36012d034d87

ref expression DataFolder

ref role 'Territory Access'
ref role 'Is My Account'

ref perspective 'Full Model'

