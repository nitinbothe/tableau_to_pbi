  "calculations": [
    {
      "tableau_calculation": "SUM([quantity] * [unit_price])",
      "pbi_table": "Orders",
      "pbi_object": "Gross Revenue",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "SUM(IF [order_status] != \"Cancelled\" THEN [quantity] * [unit_price] * (1 - [discount]) ELSE 0 END)",
      "pbi_table": "Orders",
      "pbi_object": "Net Revenue",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "SUM([quantity] * [unit_price] * [discount])",
      "pbi_table": "Orders",
      "pbi_object": "Total Discount",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "SUM(IF [order_status] != \"Cancelled\" THEN ([quantity] * [unit_price] * (1 - [discount])) - [shipping_cost] ELSE 0 END)",
      "pbi_table": "Orders",
      "pbi_object": "Profit",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "[Calc_Profit] / [Calc_NetRevenue]",
      "pbi_table": "Orders",
      "pbi_object": "Profit Margin %",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "{FIXED [customer_id] : SUM([quantity] * [unit_price])}",
      "pbi_table": "Orders",
      "pbi_object": "Revenue per Customer",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "{FIXED [region], [channel] : SUM([quantity] * [unit_price])}",
      "pbi_table": "Orders",
      "pbi_object": "Regional Channel Revenue",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "{EXCLUDE [channel] : SUM([quantity] * [unit_price])}",
      "pbi_table": "Orders",
      "pbi_object": "Revenue Excl Category",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "WINDOW_AVG(SUM([quantity] * [unit_price]))",
      "pbi_table": "Orders",
      "pbi_object": "Moving Avg Revenue",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "RUNNING_SUM(SUM([quantity] * [unit_price]))",
      "pbi_table": "Orders",
      "pbi_object": "Running Total Revenue",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "RANK(SUM([quantity] * [unit_price]))",
      "pbi_table": "Orders",
      "pbi_object": "Revenue Rank",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "{FIXED : SUM(IF YEAR([order_date]) = YEAR(TODAY()) THEN [quantity] * [unit_price] ELSE 0 END)}",
      "pbi_table": "Orders",
      "pbi_object": "YTD Revenue",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "IF [Calc_RevPerCustomer] > 10000 THEN \"Platinum\" ELSEIF [Calc_RevPerCustomer] > 5000 THEN \"Gold\" ELSEIF [Calc_RevPerCustomer] > 1000 THEN \"Silver\" ELSE \"Bronze\" END",
      "pbi_table": "Orders",
      "pbi_object": "Customer Tier",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "COUNTD([customer_id])",
      "pbi_table": "Orders",
      "pbi_object": "Unique Customers",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "AVG(IF [order_status] = \"Completed\" THEN [quantity] * [unit_price] ELSE 0 END)",
      "pbi_table": "Orders",
      "pbi_object": "AOV Completed",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "STDEV(SUM([quantity] * [unit_price]))",
      "pbi_table": "Orders",
      "pbi_object": "Revenue StdDev",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "[customer_email] = USERNAME()",
      "pbi_table": "Orders",
      "pbi_object": "Is My Account",
      "pbi_type": "measure"
    },
