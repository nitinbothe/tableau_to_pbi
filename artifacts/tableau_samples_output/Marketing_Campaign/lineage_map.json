{
  "tables": [
    {
      "tableau_datasource": "federated.marketing",
      "tableau_table": "Campaigns",
      "pbi_table": "Campaigns"
    },
    {
      "tableau_datasource": "federated.marketing",
      "tableau_table": "Leads",
      "pbi_table": "Leads"
    },
    {
      "tableau_datasource": "",
