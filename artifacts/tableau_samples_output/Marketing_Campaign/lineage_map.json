    {
      "tableau_datasource": "",
      "tableau_table": "Min Budget",
      "pbi_table": "Min Budget"
    }
  ],
  "calculations": [
    {
      "tableau_calculation": "COUNTA([lead_name])",
      "pbi_table": "Campaigns",
      "pbi_object": "Non-Blank Leads",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "CORR([budget], [deal_value])",
      "pbi_table": "Campaigns",
      "pbi_object": "Budget Deal Correlation",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "COVAR([spend], [engagement_score])",
      "pbi_table": "Campaigns",
      "pbi_object": "Spend Engagement Covar",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "{INCLUDE [channel] : AVG([deal_value])}",
      "pbi_table": "Campaigns",
      "pbi_object": "Avg Deal by Channel",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "(SUM([deal_value]) - SUM([spend])) / SUM([spend])",
      "pbi_table": "Campaigns",
      "pbi_object": "Campaign ROI",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "SUM([spend]) / COUNTD([lead_id])",
      "pbi_table": "Campaigns",
      "pbi_object": "Cost Per Lead",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "WINDOW_MAX((SUM([deal_value]) - SUM([spend])) / SUM([spend]))",
      "pbi_table": "Campaigns",
      "pbi_object": "Window Best ROI",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "WINDOW_MIN((SUM([deal_value]) - SUM([spend])) / SUM([spend]))",
      "pbi_table": "Campaigns",
      "pbi_object": "Window Worst ROI",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "RUNNING_COUNT(COUNTD([lead_id]))",
      "pbi_table": "Campaigns",
      "pbi_object": "Cumulative Leads",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "SUM(IF [lead_status] = \"Won\" THEN 1 ELSE 0 END) / COUNT([lead_id])",
      "pbi_table": "Campaigns",
      "pbi_object": "Conversion Rate",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "Target Channel",
      "pbi_table": "Campaigns",
      "pbi_object": "Target Channel",
      "pbi_type": "measure"
    },
    {
