// DAX measures for table: Orders
// Auto-generated by Tableau → Power BI migration

Is Current User =
MAX('Orders'[CustomerEmail]) = USERPRINCIPALNAME()

Manager Access =
TRUE() /* ISMEMBEROF("Managers"): implement via RLS role */ || TRUE() /* ISMEMBEROF("Executives"): implement via RLS role */

Region Match =
SUM('Regions'[RegionManager]) = USERPRINCIPALNAME()

Total Sales =
SUM('Orders'[Sales])

Profit Ratio =
SUM('Orders'[Profit]) / SUM('Orders'[Sales])

Total Sales Formatted =
VAR _val = [Total Sales] RETURN IF(ABS(_val) >= 1E9, FORMAT(_val / 1E9, "#,0.0") & "B", IF(ABS(_val) >= 1E6, FORMAT(_val / 1E6, "#,0.0") & "M", IF(ABS(_val) >= 1E3, FORMAT(_val / 1E3, "#,0.0") & "K", FORMAT(_val, "#,0.00"))))

Profit Ratio Formatted =
VAR _val = [Profit Ratio] RETURN IF(ABS(_val) >= 1E9, FORMAT(_val / 1E9, "#,0.0") & "B", IF(ABS(_val) >= 1E6, FORMAT(_val / 1E6, "#,0.0") & "M", IF(ABS(_val) >= 1E3, FORMAT(_val / 1E3, "#,0.0") & "K", FORMAT(_val, "#,0.00"))))

