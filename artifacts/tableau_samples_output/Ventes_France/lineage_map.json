  "calculations": [
    {
      "tableau_calculation": "SUM([quantite] * [prix_unitaire])",
      "pbi_table": "Commandes",
      "pbi_object": "Chiffre d'Affaires Brut",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "SUM(IF [statut] != \"Annul\u00e9e\" THEN [quantite] * [prix_unitaire] * (1 - [remise]) ELSE 0 END)",
      "pbi_table": "Commandes",
      "pbi_object": "Chiffre d'Affaires Net",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "SUM(IF [statut] != \"Annul\u00e9e\" THEN ([quantite] * [prix_unitaire] * (1 - [remise])) - ([quantite] * [cout_achat]) - [frais_port] ELSE 0 END)",
      "pbi_table": "Commandes",
      "pbi_object": "Marge Brute",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "ZN([Calc_Marge] / [Calc_CA_Net])",
      "pbi_table": "Commandes",
      "pbi_object": "Taux de Marge (%)",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "SUM([quantite] * [prix_unitaire] * [remise])",
      "pbi_table": "Commandes",
      "pbi_object": "Montant Remises",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "COUNTD([commande_id])",
      "pbi_table": "Commandes",
      "pbi_object": "Nombre de Commandes",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "COUNTD([client_id])",
      "pbi_table": "Commandes",
      "pbi_object": "Clients Uniques",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "[Calc_CA_Net] / [Calc_NbCommandes]",
      "pbi_table": "Commandes",
      "pbi_object": "Panier Moyen",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "{FIXED [client_id] : SUM([quantite] * [prix_unitaire])}",
      "pbi_table": "Commandes",
      "pbi_object": "CA par Client",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "{FIXED [region], [categorie] : SUM([quantite] * [prix_unitaire])}",
      "pbi_table": "Commandes",
      "pbi_object": "CA R\u00e9gional par Cat\u00e9gorie",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "{EXCLUDE [nom_produit] : SUM([quantite] * [prix_unitaire])}",
      "pbi_table": "Commandes",
      "pbi_object": "CA hors Produit",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "IF [Calc_CAParClient] > 50000 THEN \"Platine\" ELSEIF [Calc_CAParClient] > 20000 THEN \"Or\" ELSEIF [Calc_CAParClient] > 5000 THEN \"Argent\" ELSE \"Bronze\" END",
      "pbi_table": "Commandes",
      "pbi_object": "Classification Client",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "RUNNING_SUM(SUM([quantite] * [prix_unitaire]))",
      "pbi_table": "Commandes",
      "pbi_object": "Cumul Mobile CA",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "WINDOW_AVG(SUM([quantite] * [prix_unitaire]), -2, 0)",
      "pbi_table": "Commandes",
      "pbi_object": "Moyenne Mobile 3M",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "RANK(SUM([quantite] * [prix_unitaire]))",
      "pbi_table": "Commandes",
      "pbi_object": "Classement CA",
      "pbi_type": "measure"
    },
    {
      "tableau_calculation": "{FIXED : SUM(IF YEAR([date_commande]) = YEAR(TODAY()) THEN [quantite] * [prix_unitaire] ELSE 0 END)}",
      "pbi_table": "Commandes",
      "pbi_object": "CA Ann\u00e9e en Cours",
      "pbi_type": "measure"
    },
    {
